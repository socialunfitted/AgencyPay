# Environment variables for Supabase Edge Functions
# Set these in your Supabase project:
# Dashboard → Project Settings → Edge Functions → Secrets

# ── Required ────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
JWT_SECRET=your-supabase-jwt-secret-here   # From Project Settings > API > JWT Secret

# ── Email: Resend (resend.com) ───────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@youragency.com
EMAIL_FROM_NAME=Your Agency Name

# ── WhatsApp: Meta Cloud API ─────────────────────────────────
# Get from developers.facebook.com → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ── Optional: Cron secret (for secure pg_cron calls) ────────
CRON_SECRET=a-random-secret-string-for-cron-invocations
